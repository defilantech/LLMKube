{"version":3,"term":{"cols":110,"rows":32},"timestamp":1777966201,"idle_time_limit":2.0,"command":"/Users/defilan/stuffy/code/ai/llmkube-internal/marketing/demo-script-quickstart.sh","env":{"SHELL":"/bin/zsh"}}
[0.011, "o", "\u001b[3J\u001b[H\u001b[2J"]
[0.000, "o", "\u001b[2m# LLMKube quickstart on a kind cluster\u001b[0m\r\n\u001b[2m# Operator + Helm already installed (see the README); this is the deploy + serve flow.\u001b[0m\r\n"]
[0.000, "o", "\r\n"]
[1.004, "o", "\u001b[1;32m$\u001b[0m llmkube version\r\n"]
[0.020, "o", "llmkube version 0.7.6\r\n  git commit: unknown\r\n  build date: unknown\r\n"]
[0.001, "o", "\r\n"]
[1.007, "o", "\u001b[1;32m$\u001b[0m llmkube catalog list | head -8\r\n"]
[0.019, "o", "\r\n📚 LLMKube Model Catalog (v1.1)\r\n═══════════════════════════════════════════════════════════════════════\r\n\r\nID                  NAME                          SIZE  QUANT   USE CASE              VRAM\r\n"]
[0.000, "o", "──                  ────                          ────  ─────   ────────              ────\r\ndeepseek-r1-14b     DeepSeek R1 Distill Qwen 14B  14B   Q5_K_M  Reasoning             10-16GB\r\ndeepseek-r1-32b     DeepSeek R1 Distill Qwen 32B  32B   Q4_K_M  Complex Reasoning     18-24GB\r\n"]
[0.001, "o", "\r\n"]
[1.003, "o", "\u001b[1;32m$\u001b[0m llmkube deploy llama-3.2-3b --cpu 2 --memory 4Gi\r\n"]
[0.015, "o", "📚 Using catalog model: Llama 3.2 3B Instruct\r\n"]
[0.001, "o", "\r\n🚀 Deploying LLM inference service\r\n═══════════════════════════════════════════════\r\nName:        llama-3.2-3b\r\nNamespace:   default\r\nAccelerator: cpu\r\nReplicas:    1\r\nContext:     8192 tokens\r\nImage:       ghcr.io/ggml-org/llama.cpp:server\r\n═══════════════════════════════════════════════\r\n\r\n📦 Creating Model 'llama-3.2-3b'...\r\n"]
[0.015, "o", "   ✅ Model created\r\n\r\n⚙️  Creating InferenceService 'llama-3.2-3b'...\r\n"]
[0.003, "o", "   ✅ InferenceService created\r\n\r\nWaiting for deployment to be ready (timeout: 10m0s)...\r\n"]
[2.003, "o", "[2s] Model: Ready, Service: Creating (0/1 replicas)\r\n"]
[10.004, "o", "[12s] Model: Ready, Service: Ready (1/1 replicas)\r\n\r\n✅ Deployment ready!\r\n═══════════════════════════════════════════════\r\nModel:       llama-3.2-3b\r\nSize:        0\r\nPath:        \r\nEndpoint:    http://llama-3-2-3b.default.svc.cluster.local:8080/v1/chat/completions\r\nReplicas:    1/1\r\n═══════════════════════════════════════════════\r\n\r\n🧪 To test the inference endpoint:\r\n\r\n  # Port forward the service\r\n  kubectl port-forward -n default svc/llama-3-2-3b 8080:8080\r\n\r\n  # Send a test request\r\n  curl http://localhost:8080/v1/chat/completions \\\r\n    -H \"Content-Type: application/json\" \\\r\n    -d '{\"messages\":[{\"role\":\"user\",\"content\":\"What is 2+2?\"}]}'\r\n\r\n"]
[0.001, "o", "\r\n"]
[1.004, "o", "\u001b[1;32m$\u001b[0m kubectl get isvc llama-3.2-3b\r\n"]
[0.047, "o", "NAME           PHASE   MODEL          REPLICAS   ENDPOINT                                                                 AGE\r\n"]
[0.000, "o", "llama-3.2-3b   Ready   llama-3.2-3b   1          http://llama-3-2-3b.default.svc.cluster.local:8080/v1/chat/completions   13s\r\n"]
[0.001, "o", "\r\n"]
[4.016, "o", "\u001b[2m# Stream tokens from the OpenAI-compatible endpoint:\u001b[0m\r\n"]
[0.000, "o", "\u001b[1;32m$\u001b[0m curl -sN localhost:8080/v1/chat/completions -d '{...,\"stream\":true}' | jq -j .choices[0].delta.content\r\n"]
[2.674, "o", "Kubernetes is an open-source container orchestration system that automates the deployment, scaling, and management of containerized applications across a cluster of nodes, providing a scalable, secure, and efficient way to deploy and manage modern applications. It acts as a \"brain\" for the cluster, managing the deployment and management of containers, services, and other resources to ensure high availability, reliability, and performance of"]
[0.001, "o", "\r\n\r\n"]
[2.009, "o", "\u001b[2m# Or measure throughput with the built-in benchmark:\u001b[0m\r\n"]
[0.000, "o", "\u001b[1;32m$\u001b[0m llmkube benchmark llama-3.2-3b -i 3 --warmup 1 --max-tokens 64\r\n"]
