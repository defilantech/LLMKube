[0.306, "o", "\u001b[3J\u001b[H\u001b[2J"]
[0.001, "o", "# LLMKube quickstart on a kind cluster\r\n"]
[0.000, "o", "# Model: Llama 3.2 3B Instruct (Q5_K_M, ~2.2 GB GGUF)\r\n\r\n"]
[1.510, "o", "\u001b[1;32m$\u001b[0m llmkube version\r\n"]
[0.629, "o", "llmkube version 0.7.4\r\n  git commit: unknown\r\n  build date: unknown\r\n"]
[0.001, "o", "\r\n"]
[0.806, "o", "\u001b[1;32m$\u001b[0m llmkube catalog list | head -8\r\n"]
[0.631, "o", "\r\n📚 LLMKube Model Catalog (v1.1)\r\n═══════════════════════════════════════════════════════════════════════\r\n\r\n"]
[0.000, "o", "ID                  NAME                          SIZE  QUANT   USE CASE              VRAM\r\n──                  ────                          ────  ─────   ────────              ────\r\n"]
[0.000, "o", "deepseek-r1-14b     DeepSeek R1 Distill Qwen 14B  14B   Q5_K_M  Reasoning             10-16GB\r\ndeepseek-r1-32b     DeepSeek R1 Distill Qwen 32B  32B   Q4_K_M  Complex Reasoning     18-24GB\r\n"]
[0.002, "o", "\r\n"]
[0.808, "o", "\u001b[1;32m$\u001b[0m llmkube deploy llama-3.2-3b --cpu 2 --memory 4Gi\r\n"]
[0.634, "o", "📚 Using catalog model: Llama 3.2 3B Instruct\r\n"]
[0.002, "o", "\r\n🚀 Deploying LLM inference service\r\n═══════════════════════════════════════════════\r\nName:        llama-3.2-3b\r\nNamespace:   default\r\nAccelerator: cpu\r\nReplicas:    1\r\nContext:     8192 tokens\r\nImage:       ghcr.io/ggml-org/llama.cpp:server\r\n═══════════════════════════════════════════════\r\n\r\n📦 Creating Model 'llama-3.2-3b'...\r\n"]
[0.015, "o", "   ✅ Model created\r\n\r\n⚙️  Creating InferenceService 'llama-3.2-3b'...\r\n"]
[0.004, "o", "   ✅ InferenceService created\r\n\r\nWaiting for deployment to be ready (timeout: 10m0s)...\r\n"]
[2.005, "o", "[2s] Model: Ready, Service: Creating (0/1 replicas)\r\n"]
[31.999, "o", "[34s] Model: Ready, Service: Ready (1/1 replicas)\r\n\r\n✅ Deployment ready!\r\n═══════════════════════════════════════════════\r\nModel:       llama-3.2-3b\r\nSize:        0\r\nPath:        \r\nEndpoint:    http://llama-3-2-3b.default.svc.cluster.local:8080/v1/chat/completions\r\nReplicas:    1/1\r\n═══════════════════════════════════════════════\r\n\r\n🧪 To test the inference endpoint:\r\n\r\n  # Port forward the service\r\n  kubectl port-forward -n default svc/llama-3-2-3b 8080:8080\r\n\r\n  # Send a test request\r\n"]
[0.000, "o", "  curl http://localhost:8080/v1/chat/completions \\\r\n    -H \"Content-Type: application/json\" \\\r\n    -d '{\"messages\":[{\"role\":\"user\",\"content\":\"What is 2+2?\"}]}'\r\n\r\n"]
[0.002, "o", "\r\n"]
[0.810, "o", "\u001b[1;32m$\u001b[0m kubectl wait --for=jsonpath='{.status.phase}'=Ready isvc/llama-3.2-3b --timeout=300s\r\n"]
[0.768, "o", "inferenceservice.inference.llmkube.dev/llama-3.2-3b condition met\r\n"]
[0.002, "o", "\r\n"]
[1.008, "o", "\u001b[1;32m$\u001b[0m kubectl get isvc llama-3.2-3b\r\n"]
[0.671, "o", "NAME           PHASE   MODEL          REPLICAS   ENDPOINT                                                                 AGE\r\nllama-3.2-3b   Ready"]
[0.000, "o", "   llama-3.2-3b   1          http://llama-3-2-3b.default.svc.cluster.local:8080/v1/chat/completions   37s\r\n"]
[0.001, "o", "\r\n"]
[0.807, "o", "\u001b[1;32m$\u001b[0m kubectl port-forward svc/llama-3-2-3b 8080:8080 >/tmp/pf.log 2>&1 &\r\n"]
[0.609, "o", "\r\n"]
[2.309, "o", "\u001b[1;32m$\u001b[0m curl -sS http://localhost:8080/v1/chat/completions \\\r\n  -H \"Content-Type: application/json\" \\\r\n  -d '{\"messages\":[{\"role\":\"user\",\"content\":\"What is Kubernetes in one sentence?\"}],\"max_tokens\":50}' | jq .choices[0].message.content\r\n"]
[2.167, "o", "\u001b[0;32m\"Kubernetes (also known as K8s) is an open-source container orchestration system for automating the deployment, scaling, and management of containerized applications across multiple hosts and clusters.\"\u001b[0m\r\n"]
[0.001, "o", "\r\n"]
[0.808, "o", "\r\n"]
[0.000, "o", "# Done. The model stays cached in the per-namespace PVC for the next deploy.\r\n"]
