{"version":3,"term":{"cols":110,"rows":32},"timestamp":1777784849,"idle_time_limit":2.0,"command":"/tmp/llmkube-eviction-demo.sh","env":{"SHELL":"/bin/zsh"}}
[0.012, "o", "\u001b[3J\u001b[H\u001b[2J"]
[0.000, "o", "\u001b[2m# LLMKube memory-pressure protection (issue #186)\u001b[0m\r\n"]
[0.000, "o", "\u001b[2m# Three llama.cpp inference services. One is marked evictionProtection=true.\u001b[0m\r\n"]
[0.000, "o", "\u001b[2m# The metal-agent watchdog is configured aggressively for this demo.\u001b[0m\r\n"]
[0.000, "o", "\r\n"]
[1.003, "o", "\u001b[1;32m$\u001b[0m kubectl get isvc\r\n"]
[0.045, "o", "NAME          PHASE     MODEL              REPLICAS   ENDPOINT   AGE\r\nchat-batch    Pending   qwen3-0.6b-draft                         4m55s\r\nchat-normal   Pending   qwen3-0.6b-draft                         4m55s\r\nchat-prod     Pending   qwen3-0.6b-draft   "]
[0.000, "o", "                      4m55s\r\n"]
[0.001, "o", "\r\n"]
[2.006, "o", "\u001b[1;32m$\u001b[0m kubectl get isvc -o custom-columns='NAME:.metadata.name,PRIORITY:.spec.priority,PROTECTED:.spec.evictionProtection'\r\n"]
[0.034, "o", "NAME          PRIORITY   PROTECTED\r\nchat-batch    batch      <none>\r\nchat-normal   normal     <none>\r\nchat-prod     critical   true\r\n"]
[0.001, "o", "\r\n"]
[2.003, "o", "\u001b[2m# All three are managed by the metal-agent. Check its Prometheus endpoint:\u001b[0m\r\n"]
[0.000, "o", "\u001b[1;32m$\u001b[0m curl -s :9090/metrics | grep -E 'managed_processes|memory_pressure_level' | head -4\r\n"]
[0.018, "o", "llmkube_metal_agent_managed_processes 3\r\nllmkube_metal_agent_memory_pressure_level 2\r\n"]
[0.001, "o", "\r\n"]
[2.008, "o", "\u001b[2m# Per-process resident set size (real RSS, sampled every 5s):\u001b[0m\r\n"]
[0.000, "o", "\u001b[1;32m$\u001b[0m curl -s :9090/metrics | grep process_rss_bytes\r\n"]
[0.013, "o", "llmkube_metal_agent_process_rss_bytes{name=\"chat-batch\"} 8.67074048e+08\r\nllmkube_metal_agent_process_rss_bytes{name=\"chat-normal\"} 8.69220352e+08\r\nllmkube_metal_agent_process_rss_bytes{name=\"chat-prod\"} 8.6704128e+08\r\n"]
[0.000, "o", "\r\n"]
[2.009, "o", "\u001b[2m# Pressure is Critical (level=2). What did the watchdog say?\u001b[0m\r\n"]
[0.000, "o", "\u001b[1;32m$\u001b[0m tail -n 4 /tmp/eviction-demo-agent.log | jq -r 'select(.subsystem==\"watchdog\") | \"[\\(.subsystem)] level=\\(.level) avail=\\(.available) totalRSS=\\(.totalRSS)\"'\r\n"]
[0.008, "o", "[watchdog] level=critical avail=93.3 GB totalRSS=2.4 GB\r\n[watchdog] level=critical avail=93.6 GB totalRSS=2.4 GB\r\n[watchdog] level=critical avail=93.6 GB totalRSS=2.4 GB\r\n"]
[0.000, "o", "\r\n"]
[2.006, "o", "\u001b[2m# Each running InferenceService now carries a MemoryPressure condition.\u001b[0m\r\n"]
[0.000, "o", "\u001b[2m# Operators see the system state on their workload, not just in metrics.\u001b[0m\r\n"]
[0.000, "o", "\u001b[1;32m$\u001b[0m kubectl get isvc -o jsonpath='{range .items[*]}{.metadata.name}: {.status.conditions[?(@.type==\"MemoryPressure\")].reason}{\"\r\n\"}{end}'\r\n"]
[0.045, "o", "chat-batch: Critical\r\nchat-normal: Critical\r\nchat-prod: Critical\r\n"]
[0.001, "o", "\r\n"]
[3.003, "o", "\u001b[2m# Even chat-prod (evictionProtection=true) gets the condition — visibility is for everyone.\u001b[0m\r\n"]
[0.000, "o", "\u001b[2m# But did anything get killed? Check the eviction counters:\u001b[0m\r\n"]
[0.000, "o", "\u001b[1;32m$\u001b[0m curl -s :9090/metrics | grep -E '^llmkube_metal_agent_evictions_(skipped_)?total'\r\n"]
[0.016, "o", "llmkube_metal_agent_evictions_total 0\r\n"]
[0.000, "o", "\r\n"]
[3.007, "o", "\u001b[2m# Zero evictions. The watchdog detected Critical, decided LLMKube is NOT the source\u001b[0m\r\n"]
[0.000, "o", "\u001b[2m# of pressure (we're using 2.4 GB of 128 GB total = 1.9%, well under the 50% friendly-fire guard),\u001b[0m\r\n"]
[0.000, "o", "\u001b[2m# and explicitly held fire. The reason label tells operators why:\u001b[0m\r\n"]
[0.000, "o", "\u001b[1;32m$\u001b[0m curl -s :9090/metrics | grep evictions_skipped | grep -v '#'\r\n"]
[0.017, "o", "llmkube_metal_agent_evictions_skipped_total{reason=\"below_guard\"} 58\r\n"]
[0.001, "o", "\r\n"]
[3.009, "o", "\u001b[2m# If pressure had been our fault — e.g. one model started leaking — the watchdog\u001b[0m\r\n\u001b[2m# would have evicted the lowest-priority unprotected service (chat-batch),\u001b[0m\r\n"]
[0.000, "o", "\u001b[2m# left chat-normal alone, and refused to touch chat-prod regardless of priority.\u001b[0m\r\n"]
[0.000, "o", "\u001b[2m# The respawn block then prevents the controller from immediately recreating it.\u001b[0m\r\n"]
[0.000, "o", "\r\n"]
[2.009, "o", "\u001b[2m# Try it:  helm install llmkube/llmkube --set metalAgent.evictionEnabled=true\u001b[0m\r\n\r\n"]
[2.012, "x", "0"]
