          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "llmkube_gpuquota_admission_denials_total",
          "legendFormat": "{{gpuquota}} ({{namespace}})",
          "refId": "A"
        }
      ],
      "title": "Cumulative admission denials",
      "type": "stat"
    }
