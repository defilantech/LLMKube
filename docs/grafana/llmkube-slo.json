      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "1 - ((1 - (up:sum${window_suffix}{slo=~\"$slo\"} / up:count${window_suffix}{slo=~\"$slo\"})) / (1 - $objective/100))",
          "legendFormat": "{{slo}}",
          "refId": "A"
        }
      ],
      "title": "Availability error budget remaining over time",
