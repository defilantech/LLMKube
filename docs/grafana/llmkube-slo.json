    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "Current compliance (actual good-fraction over the SLO's 28d window) per SLO, both indicators merged into one table. Objective and window are not queryable Prometheus series in Pyrra v0.10.1; cross-check them against the InferenceService's spec.slo instead of expecting a column here.",
      "fieldConfig": {
        "defaults": {"custom": {"align": "auto", "cellOptions": {"type": "auto"}}, "unit": "percentunit"},
        "overrides": [
          {"matcher": {"id": "byName", "options": "Time"}, "properties": [{"id": "custom.hidden", "value": true}]},
          {"matcher": {"id": "byName", "options": "Value"}, "properties": [{"id": "displayName", "value": "Compliance (28d)"}]}
        ]
      },
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 24},
      "id": 7,
      "options": {
        "cellHeight": "sm",
        "footer": {"countRows": false, "fields": "", "reducer": ["sum"], "show": false},
        "showHeader": true
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "up:sum${window_suffix}{slo=~\"$slo\"} / up:count${window_suffix}{slo=~\"$slo\"}",
          "format": "table",
          "instant": true,
          "legendFormat": "__auto",
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "vllm:e2e_request_latency_seconds:increase${window_suffix}{slo=~\"$slo\", le=\"2\"} / ignoring(le) vllm:e2e_request_latency_seconds:increase${window_suffix}{slo=~\"$slo\", le=\"\"}",
          "format": "table",
          "instant": true,
          "legendFormat": "__auto",
          "refId": "B"
        }
      ],
      "transformations": [
        {"id": "merge", "options": {}},
        {"id": "organize", "options": {"excludeByName": {"Time": true, "le": true, "namespace": true, "service": true}, "indexByName": {}, "renameByName": {"Value": "Compliance (28d)"}}}
      ],
      "title": "SLO overview (availability + latency)",
      "type": "table"
    }
